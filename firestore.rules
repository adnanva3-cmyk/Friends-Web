rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: settings
    // Document ID: home
    // Fields: heroTitle, heroSubtitle, heroBg, heroGradientStrength, heroImage, heroOpacity
    //
    // Collection: settings
    // Document ID: contact
    // Fields: phone, secondaryPhone, email, whatsapp, branches
    //
    // Collection: products
    // Document ID: {productId}
    // Fields: name, description, image, bgImage, category, price
    //
    // Collection: slides
    // Document ID: {slideId}
    // Fields: title, subtitle, description, image, layout, type, shape, rounded, fit, align
    //
    // ===============================================================

    // ===============================================================
    // Rules
    // ===============================================================

    match /settings/{document=**} {
      allow read: if true;
      allow write: if true;
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if true;
    }

    match /slides/{slideId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
